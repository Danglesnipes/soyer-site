---
// PLACEHOLDER SECTION — real capabilities not confirmed yet.
// Layout shell only. Do not replace with feature claims until copy is finalized.
const bullets = ["[Capability 1]", "[Capability 2]", "[Capability 3]"];
---

<section class="solo section" aria-labelledby="solo-heading">
	<div class="container">
		<p class="eyebrow eyebrow--placeholder">Placeholder — copy to come</p>
		<h2 id="solo-heading" class="solo__heading">Works solo or with a team</h2>
		<p class="solo__intro is-placeholder">
			[Intro — the "flexes to your size" idea, to be finalized]
		</p>

		<ul class="solo__grid">
			{
				bullets.map((bullet) => (
					<li class="solo-card is-placeholder">{bullet}</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.solo__heading {
		font-size: clamp(1.625rem, 4.5vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.015em;
		margin-top: 0.5rem;
	}

	/* Placeholder treatment — deliberately unfinished so it reads as a stub */
	.eyebrow--placeholder {
		color: var(--color-text-muted);
	}

	.is-placeholder {
		color: var(--color-text-muted);
		border: 1px dashed var(--color-primary);
		border-radius: var(--radius);
		background: color-mix(in srgb, var(--color-primary) 6%, transparent);
		font-style: italic;
	}

	.solo__intro {
		margin-top: 1.25rem;
		font-size: clamp(1.0625rem, 2.2vw, 1.25rem);
		max-width: 60ch;
		padding: 0.75rem 1rem;
	}

	.solo__grid {
		list-style: none;
		padding: 0;
		margin: 2rem 0 0;
		display: grid;
		gap: 1.25rem;
		grid-template-columns: 1fr;
	}

	.solo-card {
		padding: 1.75rem;
		font-weight: 600;
	}

	@media (min-width: 720px) {
		.solo__grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 1.5rem;
		}
	}
</style>
