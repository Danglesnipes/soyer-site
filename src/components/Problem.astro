---
// Scattered job artifacts for the "chaos-to-pack" visual.
// Neutral/muted cards (site surface+border tokens); amber is reserved for the pack payoff.
const icons = {
	photos: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.5A1.5 1.5 0 0 1 4.5 7H7l1.2-1.6a1 1 0 0 1 .8-.4h6a1 1 0 0 1 .8.4L17 7h2.5A1.5 1.5 0 0 1 21 8.5v9A1.5 1.5 0 0 1 19.5 19h-15A1.5 1.5 0 0 1 3 17.5Z"/><circle cx="12" cy="13" r="3.2"/></svg>`,
	video: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="m10 9.4 4.6 2.6L10 14.6Z"/></svg>`,
	shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5 19 6v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6Z"/><path d="m9 11.6 2 2 4-4"/></svg>`,
	doc: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3.5h7L18 8v12.5H6Z"/><path d="M13 3.5V8h5"/><path d="M9 13h6M9 16.5h4"/></svg>`,
	invoice: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3.5h12v17l-2.2-1.4L13.5 20l-2.3-1.4L9 20l-2.3-1.4L6 20Z"/><path d="M9 8h6M9 11.5h6"/></svg>`,
	stack: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="7" width="13" height="13" rx="2"/><path d="M4 16.5V5.5A1.5 1.5 0 0 1 5.5 4H16"/><circle cx="11.5" cy="12" r="1.5"/><path d="m7.5 18.5 3-3 3 2.4"/></svg>`,
	check: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8.5"/><path d="m8.5 12 2.3 2.3L15.5 10"/></svg>`,
	pen: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16"/><path d="M14.5 5.5 18 9l-8 8H6.5V13.5Z"/><path d="m13 7 3.5 3.5"/></svg>`,
};

const packIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 7.5 12 3l8.5 4.5v9L12 21l-8.5-4.5Z"/><path d="M3.5 7.5 12 12l8.5-4.5"/><path d="M12 12v9"/></svg>`;
const badgeIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12.5 4 4 10-10"/></svg>`;
const replayIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 2.6-6.4"/><path d="M4 3v4h4"/></svg>`;

const cards = [
	{ icon: icons.photos,  label: "Job photos",   src: "camera roll",   x: "20%", y: "21%", r: "-8deg",  delay: "0ms",   jdur: "2.4s", jdelay: "-0.2s" },
	{ icon: icons.video,   label: "Site video",   src: "texts",         x: "76%", y: "17%", r: "7deg",   delay: "60ms",  jdur: "2.9s", jdelay: "-1.1s" },
	{ icon: icons.shield,  label: "Compliance",   src: "email",         x: "14%", y: "52%", r: "6deg",   delay: "120ms", jdur: "2.6s", jdelay: "-0.6s" },
	{ icon: icons.doc,     label: "Change order", src: "email",         x: "83%", y: "46%", r: "-6deg",  delay: "180ms", jdur: "3.1s", jdelay: "-1.6s" },
	{ icon: icons.invoice, label: "Invoice",      src: "home computer", x: "28%", y: "83%", r: "9deg",   delay: "240ms", jdur: "2.5s", jdelay: "-0.9s" },
	{ icon: icons.stack,   label: "More photos",  src: "Dropbox",       x: "62%", y: "80%", r: "-7deg",  delay: "300ms", jdur: "2.8s", jdelay: "-0.4s" },
	{ icon: icons.check,   label: "Approvals",    src: "WhatsApp",      x: "47%", y: "37%", r: "3deg",   delay: "360ms", jdur: "3.0s", jdelay: "-1.3s" },
	{ icon: icons.pen,     label: "Sign-off",     src: "email",         x: "86%", y: "82%", r: "-10deg", delay: "420ms", jdur: "2.3s", jdelay: "-0.7s" },
];
---

<section class="problem section" aria-labelledby="problem-heading">
	<div class="container">
		<div class="problem__grid">
			<div class="problem__text">
				<p class="eyebrow">The problem</p>
				<h2 id="problem-heading" class="problem__heading">
					You did the work weeks ago. You're still waiting on the money.
					Chasing payment has become a second job.
				</h2>
				<p class="problem__body">
					Photos and videos are on your phone. Compliance docs are in your
					email. The invoice is on the computer at home. Every GC wants them
					packaged differently, and every rejection is another week you don't
					get paid.
				</p>
			</div>

			<div class="problem__visual">
				<div class="chaos" data-chaos role="img"
					aria-label="Scattered job files — photos, videos, compliance docs, invoices — pulling together into one Job pack.">
					{
						cards.map((card) => (
							<div
								class="chaos-card"
								style={`--x:${card.x};--y:${card.y};--r:${card.r};--delay:${card.delay};--jdur:${card.jdur};--jdelay:${card.jdelay};`}
							>
								<span class="chaos-card__icon" aria-hidden="true" set:html={card.icon} />
								<span class="chaos-card__label">{card.label}</span>
								<span class="chaos-card__src">{card.src}</span>
							</div>
						))
					}

					<div class="chaos-pack" aria-label="Job pack">
						<span class="chaos-pack__icon" aria-hidden="true" set:html={packIcon} />
						<span class="chaos-pack__label">Job pack</span>
						<span class="chaos-pack__badge">
							<span class="chaos-pack__badge-icon" aria-hidden="true" set:html={badgeIcon} />
							Ready to send
						</span>
					</div>
				</div>

				<button type="button" class="chaos-replay" data-chaos-replay>
					<span class="chaos-replay__icon" aria-hidden="true" set:html={replayIcon} />
					Replay
				</button>
			</div>
		</div>
	</div>
</section>

<style>
	.problem {
		background: var(--color-surface);
		border-block: 1px solid var(--color-border);
	}

	.problem__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(2rem, 5vw, 3.5rem);
		align-items: center;
	}

	.problem__text {
		min-width: 0;
	}

	.problem__heading {
		font-size: clamp(1.625rem, 4.5vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.015em;
		line-height: 1.15;
		margin-top: 0.5rem;
		max-width: 28ch;
	}

	.problem__body {
		margin-top: 1.25rem;
		font-size: clamp(1.0625rem, 2.2vw, 1.25rem);
		color: var(--color-text-muted);
		max-width: 60ch;
	}

	/* ----- Animated chaos-to-pack visual ----- */
	.problem__visual {
		min-width: 0;
	}

	.chaos {
		position: relative;
		width: 100%;
		min-height: clamp(330px, 46vw, 430px);
		overflow: hidden;
	}

	.chaos-card {
		position: absolute;
		left: var(--x);
		top: var(--y);
		width: clamp(112px, 33%, 140px);
		translate: -50% -50%;
		rotate: var(--r);
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		padding: 0.6rem 0.7rem;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		box-shadow: var(--shadow);
		transition:
			left 0.5s ease-in,
			top 0.5s ease-in,
			scale 0.5s ease-in,
			opacity 0.4s ease-in;
		transition-delay: var(--delay);
		will-change: left, top, scale, opacity;
	}

	.chaos-card__icon {
		display: inline-flex;
		color: var(--color-text-muted);
	}

	.chaos-card__icon :global(svg) {
		width: 20px;
		height: 20px;
	}

	.chaos-card__label {
		font-size: 0.8125rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--color-text);
	}

	.chaos-card__src {
		align-self: flex-start;
		font-size: 0.625rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		padding: 0.1rem 0.45rem;
	}

	/* The amber payoff card */
	.chaos-pack {
		position: absolute;
		left: 50%;
		top: 50%;
		translate: -50% -50%;
		width: clamp(150px, 55%, 205px);
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.5rem;
		padding: 1rem 1.15rem;
		background: var(--color-surface);
		border: 1.5px solid var(--color-primary);
		border-radius: var(--radius-lg);
		box-shadow:
			0 0 0 4px color-mix(in srgb, var(--color-primary) 14%, transparent),
			var(--shadow);
		opacity: 0;
		scale: 0.82;
		transition:
			opacity 0.5s ease,
			scale 0.55s cubic-bezier(0.2, 0.85, 0.3, 1.25);
		transition-delay: 0.5s;
	}

	.chaos-pack__icon {
		display: inline-flex;
		color: var(--color-primary);
	}

	.chaos-pack__icon :global(svg) {
		width: 28px;
		height: 28px;
	}

	.chaos-pack__label {
		font-size: 1.05rem;
		font-weight: 800;
		letter-spacing: -0.01em;
		color: var(--color-text);
	}

	.chaos-pack__badge {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--color-primary);
	}

	.chaos-pack__badge-icon {
		display: inline-flex;
	}

	.chaos-pack__badge-icon :global(svg) {
		width: 14px;
		height: 14px;
	}

	/* Assembly: cards fly to center, shrink, fade — then the pack resolves in */
	.chaos.is-assembled .chaos-card {
		left: 50%;
		top: 50%;
		scale: 0.08;
		opacity: 0;
		animation: none;
	}

	.chaos.is-assembled .chaos-pack {
		opacity: 1;
		scale: 1;
	}

	.chaos-replay {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin-top: 1rem;
		background: transparent;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		color: var(--color-text-muted);
		font-family: inherit;
		font-size: 0.8125rem;
		font-weight: 600;
		padding: 0.4rem 0.8rem;
		cursor: pointer;
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.chaos-replay__icon {
		display: inline-flex;
	}

	.chaos-replay__icon :global(svg) {
		width: 15px;
		height: 15px;
	}

	.chaos-replay:hover {
		color: var(--color-primary);
		border-color: var(--color-primary);
	}

	.chaos-replay:focus-visible {
		outline: 3px solid var(--color-primary);
		outline-offset: 3px;
	}

	/* Continuous jitter only when motion is welcome */
	@media (prefers-reduced-motion: no-preference) {
		.chaos-card {
			animation: chaosJitter var(--jdur, 2.6s) var(--jdelay, 0s) ease-in-out
				infinite alternate;
		}

		.chaos-card:nth-child(even) {
			animation-direction: alternate-reverse;
		}
	}

	@keyframes chaosJitter {
		from {
			translate: -50% -50%;
			rotate: var(--r);
		}
		to {
			translate: calc(-50% + 5px) calc(-50% - 4px);
			rotate: calc(var(--r) + 2.2deg);
		}
	}

	/* Reduced motion: no jitter, no fly-in — just the resolved pack */
	@media (prefers-reduced-motion: reduce) {
		.chaos {
			min-height: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			padding-block: 2rem;
		}

		.chaos-card {
			display: none;
		}

		.chaos-pack {
			position: relative;
			left: auto;
			top: auto;
			translate: 0 0;
			opacity: 1;
			scale: 1;
			transition: none;
		}

		.chaos-replay {
			display: none;
		}
	}

	@media (min-width: 880px) {
		.problem__grid {
			grid-template-columns: 48fr 52fr;
		}
	}
</style>

<script>
	const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
	const chaos = document.querySelector<HTMLElement>("[data-chaos]");

	if (chaos && !reduce.matches) {
		const replay = chaos.parentElement?.querySelector<HTMLButtonElement>(
			"[data-chaos-replay]",
		);
		let played = false;
		const play = () => chaos.classList.add("is-assembled");

		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting && entry.intersectionRatio >= 0.4 && !played) {
						played = true;
						play();
						io.disconnect();
					}
				}
			},
			{ threshold: [0, 0.4, 0.75] },
		);
		io.observe(chaos);

		replay?.addEventListener("click", () => {
			chaos.classList.remove("is-assembled");
			// Let the cards scatter back out, then re-run the assembly.
			window.setTimeout(play, 650);
		});
	}
</script>
