---
// Problem section: two-column layout (copy left / animated visual right on
// desktop, stacked on mobile). The visual is a looping "you'll never get paid"
// animation — pieces assemble slowly into a submission pack, then every cycle
// the GC rejects it a different way while a "days unpaid" clock climbs to 180.
const icons = {
	photos: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.5A1.5 1.5 0 0 1 4.5 7H7l1.2-1.6a1 1 0 0 1 .8-.4h6a1 1 0 0 1 .8.4L17 7h2.5A1.5 1.5 0 0 1 21 8.5v9A1.5 1.5 0 0 1 19.5 19h-15A1.5 1.5 0 0 1 3 17.5Z"/><circle cx="12" cy="13" r="3.2"/></svg>`,
	video: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="m10 9.4 4.6 2.6L10 14.6Z"/></svg>`,
	shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5 19 6v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6Z"/><path d="m9 11.6 2 2 4-4"/></svg>`,
	doc: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3.5h7L18 8v12.5H6Z"/><path d="M13 3.5V8h5"/><path d="M9 13h6M9 16.5h4"/></svg>`,
	invoice: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3.5h12v17l-2.2-1.4L13.5 20l-2.3-1.4L9 20l-2.3-1.4L6 20Z"/><path d="M9 8h6M9 11.5h6"/></svg>`,
	stack: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="7" width="13" height="13" rx="2"/><path d="M4 16.5V5.5A1.5 1.5 0 0 1 5.5 4H16"/><circle cx="11.5" cy="12" r="1.5"/><path d="m7.5 18.5 3-3 3 2.4"/></svg>`,
	pen: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16"/><path d="M14.5 5.5 18 9l-8 8H6.5V13.5Z"/><path d="m13 7 3.5 3.5"/></svg>`,
	building: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V5a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v16"/><path d="M14 9h5a1 1 0 0 1 1 1v11"/><path d="M2 21h20"/><path d="M7 8h.01M10.5 8h.01M7 12h.01M10.5 12h.01M7 16h.01M10.5 16h.01M17 13h.01M17 17h.01"/></svg>`,
};

// s* = scattered start; p* = resting slot inside the pack (design space 580x448).
// index 2 (Compliance) is the piece that expires on odd cycles.
const pieces = [
	{ icon: icons.photos,  label: "Job photos",   src: "camera roll", sx: 40,  sy: 30,  sr: -7, px: 184, py: 160, pr: -3 },
	{ icon: icons.video,   label: "Site video",   src: "texts",       sx: 225, sy: 20,  sr: 6,  px: 188, py: 172, pr: 2 },
	{ icon: icons.shield,  label: "Compliance",   src: "email",       sx: 28,  sy: 150, sr: 5,  px: 183, py: 184, pr: -2 },
	{ icon: icons.doc,     label: "Change order", src: "email",       sx: 250, sy: 146, sr: -6, px: 187, py: 196, pr: 3 },
	{ icon: icons.invoice, label: "Invoice",      src: "home pc",     sx: 55,  sy: 275, sr: 8,  px: 184, py: 208, pr: -1 },
	{ icon: icons.stack,   label: "More photos",  src: "Dropbox",     sx: 250, sy: 288, sr: -5, px: 188, py: 220, pr: 2 },
	{ icon: icons.pen,     label: "Sign-off",     src: "WhatsApp",    sx: 150, sy: 96,  sr: 3,  px: 185, py: 232, pr: -2 },
];
---

<section class="problem section" aria-labelledby="problem-heading">
	<div class="container">
		<div class="problem__grid">
			<div class="problem__text">
				<p class="eyebrow">The problem</p>
				<h2 id="problem-heading" class="problem__heading">
					You did the work weeks ago. You're still waiting on the money.
					Chasing payment has become a second job.
				</h2>
				<p class="problem__body">
					Photos and videos are on your phone. Compliance docs are in your
					email. The invoice is on the computer at home. Every GC wants them
					packaged differently, and every rejection is another week you don't
					get paid.
				</p>
			</div>

			<div class="problem__visual">
				<div
					class="stage"
					data-stage
					role="img"
					aria-label="An animation: job files slowly assemble into a submission pack, the general contractor rejects it, and a 'days unpaid' counter keeps climbing."
				>
					<!-- days-unpaid meter -->
					<div class="stage-meter" data-meter>
						<span class="stage-meter__num" data-meter-num>47</span>
						<span class="stage-meter__label">days unpaid</span>
					</div>

					<!-- phase caption -->
					<p class="stage-phase" data-phase>Still waiting to get paid.</p>

					<!-- your GC wall -->
					<div class="gc-wall" aria-hidden="true">
						<span class="gc-wall__icon" set:html={icons.building} />
						<span class="gc-wall__label">your GC</span>
					</div>

					<!-- submission pack -->
					<span class="pack-label" aria-hidden="true">your submission pack</span>
					<div class="pack-box" aria-hidden="true"></div>

					<!-- piece cards -->
					{
						pieces.map((p, i) => (
							<div
								class="piece"
								data-piece
								data-i={i}
								data-sx={p.sx} data-sy={p.sy} data-sr={p.sr}
								data-px={p.px} data-py={p.py} data-pr={p.pr}
								style={`transform: translate(${p.sx}px, ${p.sy}px) rotate(${p.sr}deg); z-index:${1 + i};`}
							>
								<span class="piece__row">
									<span class="piece__icon" aria-hidden="true" set:html={p.icon} />
									<span class="piece__label">{p.label}</span>
								</span>
								<span class="piece__src">{p.src}</span>
							</div>
						))
					}

					<!-- new-approval card (slides in from the GC wall) -->
					<div class="approval" data-approval style="transform: translate(600px, 150px) rotate(-2deg);">
						<span class="approval__t">New approval required</span>
						<span class="approval__s">added by your GC</span>
					</div>

					<!-- expired badge (fades in above the lifted compliance piece) -->
					<div class="expired-badge" data-badge>Expired while you waited</div>

					<!-- rejected stamp -->
					<div class="stamp" data-stamp aria-hidden="true">
						<span class="stamp__inner">Rejected</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.problem {
		background: var(--color-surface);
		border-block: 1px solid var(--color-border);
	}

	.problem__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(2rem, 5vw, 3.5rem);
		align-items: center;
	}

	.problem__text {
		min-width: 0;
	}

	.problem__heading {
		font-size: clamp(1.625rem, 4.5vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.015em;
		line-height: 1.15;
		margin-top: 0.5rem;
		max-width: 28ch;
	}

	.problem__body {
		margin-top: 1.25rem;
		font-size: clamp(1.0625rem, 2.2vw, 1.25rem);
		color: var(--color-text-muted);
		max-width: 60ch;
	}

	/* ---------- Animation stage ---------- */
	.problem__visual {
		min-width: 0;
	}

	.stage {
		position: relative;
		width: 100%;
		max-width: 580px;
		margin-inline: auto;
		aspect-ratio: 580 / 448;
		overflow: hidden;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		container-type: inline-size;
	}

	/* meter */
	.stage-meter {
		position: absolute;
		top: 12px;
		left: 12px;
		z-index: 6;
		display: flex;
		flex-direction: column;
		padding: 7px 12px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
	}

	.stage-meter__num {
		font-size: 30px;
		font-weight: 800;
		line-height: 1;
		letter-spacing: -0.02em;
		font-variant-numeric: tabular-nums;
		color: var(--color-danger);
	}

	.stage-meter__label {
		margin-top: 3px;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-text-muted);
	}

	.stage-meter.is-maxed {
		border-color: var(--color-danger);
		background: color-mix(in srgb, var(--color-danger) 16%, var(--color-surface));
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-danger) 22%, transparent);
	}

	/* phase caption */
	.stage-phase {
		position: absolute;
		top: 14px;
		right: 108px;
		max-width: 150px;
		z-index: 6;
		text-align: right;
		font-size: 12px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--color-text-muted);
	}

	/* GC wall */
	.gc-wall {
		position: absolute;
		top: 0;
		right: 0;
		width: 96px;
		height: 100%;
		z-index: 1;
		border-left: 2px dashed var(--color-border);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		color: var(--color-text-muted);
	}

	.gc-wall__icon :global(svg) {
		width: 28px;
		height: 28px;
	}

	.gc-wall__label {
		font-size: 12px;
		font-weight: 700;
	}

	/* pack box + label (positioned as % so they scale with the stage) */
	.pack-label {
		position: absolute;
		left: calc(100% * 150 / 580);
		top: calc(100% * 126 / 448);
		z-index: 2;
		font-size: 12px;
		font-weight: 700;
		color: var(--color-text-muted);
	}

	.pack-box {
		position: absolute;
		left: calc(100% * 150 / 580);
		top: calc(100% * 150 / 448);
		width: calc(100% * 210 / 580);
		height: calc(100% * 192 / 448);
		z-index: 2;
		border: 2px dashed var(--color-border);
		border-radius: 14px;
	}

	/* piece cards — fixed-ish size (kept legible), positions scale via JS */
	.piece {
		position: absolute;
		top: 0;
		left: 0;
		width: clamp(112px, 36cqw, 130px);
		z-index: 3;
		padding: 8px 10px;
		display: flex;
		flex-direction: column;
		gap: 5px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 11px;
		box-shadow: var(--shadow);
		transform-origin: center;
		will-change: transform;
	}

	.piece__row {
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.piece__icon {
		display: inline-flex;
		color: var(--color-text-muted);
	}

	.piece__icon :global(svg) {
		width: 16px;
		height: 16px;
	}

	.piece__label {
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.1;
		color: var(--color-text);
	}

	.piece__src {
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.piece.is-expired {
		border-color: var(--color-danger);
		background: color-mix(in srgb, var(--color-danger) 14%, var(--color-surface));
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-danger) 22%, transparent);
	}

	.piece.is-expired .piece__label,
	.piece.is-expired .piece__icon {
		color: var(--color-danger);
	}

	/* new-approval card (amber) */
	.approval {
		position: absolute;
		top: 0;
		left: 0;
		width: 150px;
		z-index: 55;
		padding: 8px 11px;
		display: flex;
		flex-direction: column;
		gap: 2px;
		background: color-mix(in srgb, var(--color-primary) 16%, var(--color-surface));
		border: 1.5px solid var(--color-primary);
		border-radius: 11px;
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 16%, transparent);
		opacity: 0;
		transform-origin: center;
		will-change: transform, opacity;
	}

	.approval__t {
		font-size: 12px;
		font-weight: 800;
		color: var(--color-primary);
	}

	.approval__s {
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	/* expired badge (red) */
	.expired-badge {
		position: absolute;
		top: 0;
		left: 0;
		width: 160px;
		z-index: 61;
		padding: 5px 8px;
		text-align: center;
		white-space: nowrap;
		background: color-mix(in srgb, var(--color-danger) 18%, var(--color-surface));
		border: 1px solid var(--color-danger);
		border-radius: 999px;
		color: var(--color-danger);
		font-size: 11px;
		font-weight: 700;
		opacity: 0;
		transform-origin: center;
		will-change: transform, opacity;
	}

	/* rejected stamp — full-stage overlay, slams in over the pack */
	.stamp {
		position: absolute;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s ease;
	}

	.stamp__inner {
		padding: 2px 18px;
		border: 5px solid var(--color-danger);
		border-radius: 10px;
		color: var(--color-danger);
		font-size: clamp(30px, 9cqw, 52px);
		font-weight: 900;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transform: rotate(-11deg) scale(2.4);
		transform-origin: center;
		transition: transform 0.3s cubic-bezier(0.2, 1.5, 0.35, 1);
	}

	.stamp.is-slammed {
		opacity: 1;
	}

	.stamp.is-slammed .stamp__inner {
		transform: rotate(-11deg) scale(1);
	}

	@media (min-width: 880px) {
		.problem__grid {
			grid-template-columns: 48fr 52fr;
		}
	}

	/* Reduced motion: no transitions on any stage piece; JS renders a static
	   scattered mess and never animates. */
	@media (prefers-reduced-motion: reduce) {
		.stage-meter,
		.stamp,
		.stamp__inner {
			transition: none !important;
		}
	}
</style>

<script>
	const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
	const stage = document.querySelector<HTMLElement>("[data-stage]");

	if (stage) {
		const pieces = Array.from(
			stage.querySelectorAll<HTMLElement>("[data-piece]"),
		);
		const meter = stage.querySelector<HTMLElement>("[data-meter]")!;
		const meterNum = stage.querySelector<HTMLElement>("[data-meter-num]")!;
		const phaseEl = stage.querySelector<HTMLElement>("[data-phase]")!;
		const approval = stage.querySelector<HTMLElement>("[data-approval]")!;
		const badge = stage.querySelector<HTMLElement>("[data-badge]")!;
		const stamp = stage.querySelector<HTMLElement>("[data-stamp]")!;

		const num = (el: HTMLElement, k: string) => parseFloat(el.dataset[k] || "0");
		const scaleOf = () => stage.clientWidth / 580;

		type Pos = { x: number; y: number; rot: number; sc: number };
		const posOf = new WeakMap<HTMLElement, Pos>();

		function apply(el: HTMLElement, p: Pos) {
			const s = scaleOf();
			el.style.transform = `translate(${(p.x * s).toFixed(2)}px, ${(p.y * s).toFixed(2)}px) rotate(${p.rot}deg) scale(${p.sc})`;
		}

		function move(
			el: HTMLElement,
			x: number,
			y: number,
			rot: number,
			sc: number,
			transition: string,
		) {
			const p = { x, y, rot, sc };
			posOf.set(el, p);
			el.style.transition = transition;
			apply(el, p);
		}

		// Re-apply resting transforms on resize (positions scale with the stage).
		const movers = [...pieces, approval, badge];
		new ResizeObserver(() => {
			for (const el of movers) {
				const p = posOf.get(el);
				if (!p) continue;
				const keep = el.style.transition;
				el.style.transition = "none";
				apply(el, p);
				void el.offsetWidth;
				el.style.transition = keep;
			}
		}).observe(stage);

		function scatter(el: HTMLElement, transition: string) {
			move(el, num(el, "sx"), num(el, "sy"), num(el, "sr"), 1, transition);
			el.style.opacity = "1";
		}

		// Static scatter for the initial render (correct scale before anything runs).
		pieces.forEach((el) => scatter(el, "none"));

		// ----- Reduced motion: static scattered mess, meter 47, no loop -----
		if (reduce.matches) {
			meterNum.textContent = "47";
			phaseEl.textContent = "Weeks of work — still unpaid.";
		} else {
			// ----- Clock (continuous across loops; only the 180-cap resets it) -----
			let day = 1;
			let capped = false;
			let curSpeed = 360;
			let clockTimer: number | null = null;
			let visible = false;
			let waiters: Array<() => void> = [];

			const renderDay = () => (meterNum.textContent = String(Math.round(day)));

			function tick() {
				if (capped) return;
				day += 1;
				if (day >= 180) {
					day = 180;
					capped = true;
					meter.classList.add("is-maxed");
				}
				renderDay();
			}

			function startClock(ms: number) {
				curSpeed = ms;
				if (clockTimer !== null) clearInterval(clockTimer);
				clockTimer = visible ? window.setInterval(tick, ms) : null;
			}

			function setVisible(v: boolean) {
				if (v === visible) return;
				visible = v;
				if (v) {
					waiters.forEach((r) => r());
					waiters = [];
					if (started) startClock(curSpeed);
				} else if (clockTimer !== null) {
					clearInterval(clockTimer);
					clockTimer = null;
				}
			}

			const whenVisible = () =>
				visible ? Promise.resolve() : new Promise<void>((r) => waiters.push(r));
			const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
			const phase = (t: string) => (phaseEl.textContent = t);

			const EXPIRED = 2;
			const slot = (el: HTMLElement) => ({
				x: num(el, "px"),
				y: num(el, "py"),
				rot: num(el, "pr"),
			});

			function assemble(i: number) {
				const el = pieces[i];
				el.style.zIndex = String(10 + i);
				const s = slot(el);
				// heavy decelerating drift toward the slot...
				move(
					el,
					s.x,
					s.y - 18,
					s.rot * 0.6,
					0.96,
					"transform 1.2s cubic-bezier(.9,.03,.69,.22)",
				);
				// ...then settle into the stacked slot.
				window.setTimeout(() => {
					move(el, s.x, s.y, s.rot, 0.9, "transform .75s cubic-bezier(.18,.7,.32,1)");
				}, 1180);
			}

			function liftExpired() {
				const el = pieces[EXPIRED];
				const s = slot(el);
				el.style.zIndex = "60";
				el.classList.add("is-expired");
				move(el, s.x, s.y - 74, 0, 1.28, "transform .6s cubic-bezier(.2,.8,.3,1.1)");
				// badge directly above the lifted (scaled) piece
				move(badge, s.x - 15, s.y - 114, 0, 1, "none");
				requestAnimationFrame(() => {
					badge.style.transition = "opacity .5s ease";
					badge.style.opacity = "1";
				});
			}

			function slideApproval() {
				approval.style.opacity = "1";
				requestAnimationFrame(() => {
					move(approval, 250, 150, -3, 1, "transform .85s cubic-bezier(.2,.7,.3,1)");
				});
			}

			function resetMovers() {
				// hide reason cards + stamp, put approval back off-stage right.
				// Stamp visibility is class-driven only — never set inline opacity on
				// it, or the inline style would beat the .is-slammed rule.
				stamp.classList.remove("is-slammed");
				badge.style.opacity = "0";
				approval.style.opacity = "0";
				move(approval, 600, 150, -2, 1, "none");
				pieces[EXPIRED].classList.remove("is-expired");
			}

			let started = false;
			let cycleN = 0;

			async function cycle(n: number) {
				await whenVisible();

				// 180-cap gut-punch: hold red, then reset to 1 and start over.
				if (capped) {
					phase("180 days — still nothing");
					await sleep(1400);
					day = 1;
					capped = false;
					meter.classList.remove("is-maxed");
					renderDay();
					phase("And you start over…");
					await sleep(900);
				}

				// scatter the pieces back out (visible reset) + clear last cycle
				resetMovers();
				pieces.forEach((el, i) => {
					el.style.zIndex = String(1 + i);
					scatter(el, "transform .6s cubic-bezier(.5,.1,.4,1)");
				});
				startClock(360);
				phase("Back to packaging it all up");
				await sleep(750);

				// slow, halting one-at-a-time assembly
				for (let i = 0; i < pieces.length; i++) {
					assemble(i);
					await sleep(560);
				}
				await sleep(1000); // let the last piece settle

				// brief hopeful beat
				phase("Pack complete — submitted");
				await sleep(1000);

				// rejection reason alternates per cycle
				if (n % 2 === 0) {
					phase("Your GC adds a requirement");
					slideApproval();
				} else {
					phase("A compliance doc expired");
					liftExpired();
				}
				await sleep(1350);

				// rejected — time bleeds faster
				phase("Rejected — and still unpaid");
				startClock(150);
				stamp.classList.add("is-slammed");
				await sleep(1500);

				// fade everything out; expired piece returns to neutral
				stamp.classList.remove("is-slammed");
				approval.style.transition = "opacity .5s ease";
				approval.style.opacity = "0";
				badge.style.opacity = "0";
				pieces[EXPIRED].classList.remove("is-expired");
				await sleep(500);
				startClock(360);
			}

			async function run() {
				if (started) return;
				started = true;
				renderDay();
				startClock(360);
				while (true) {
					await cycle(cycleN);
					cycleN += 1;
				}
			}

			const io = new IntersectionObserver(
				(entries) => {
					for (const e of entries) {
						setVisible(e.isIntersecting && e.intersectionRatio > 0);
						if (e.isIntersecting && e.intersectionRatio >= 0.4) run();
					}
				},
				{ threshold: [0, 0.4, 0.75] },
			);
			io.observe(stage);
		}
	}
</script>
