---
const APP_URL = "https://app.soyer.tech";
---

<header class="hero section">
	<div class="container">
		<p class="eyebrow">For construction subcontractors</p>
		<h1 class="hero__headline">Stop chasing. Start getting paid.</h1>
		<p class="hero__subline">Soyer turns work into cash.</p>
		<p class="hero__support">
			Capture every job, package the paperwork your GC needs, and submit it in
			one place — so the money you earned actually shows up.
		</p>
		<a class="btn-primary" href={APP_URL}>Open Soyer</a>
	</div>
</header>

<style>
	.hero {
		padding-block: clamp(4rem, 12vw, 8rem);
	}

	.hero__headline {
		font-size: clamp(2.25rem, 7vw, 3.75rem);
		line-height: 1.08;
		font-weight: 800;
		letter-spacing: -0.02em;
		margin-top: 1rem;
		max-width: 16ch;
	}

	.hero__subline {
		font-size: clamp(1.25rem, 3.5vw, 1.75rem);
		font-weight: 600;
		color: var(--color-text);
		margin-top: 1.25rem;
	}

	.hero__support {
		font-size: clamp(1rem, 2.2vw, 1.1875rem);
		color: var(--color-text-muted);
		margin-top: 1rem;
		max-width: 48ch;
	}

	.hero .btn-primary {
		margin-top: 2rem;
	}
</style>
