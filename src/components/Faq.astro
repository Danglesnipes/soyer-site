---
const faqs = [
	{
		q: "I'm not much for apps and tech. Is this hard to use?",
		a: "No. If you can take a photo and send a text, you can use Soyer. It's built for the job site, not the office — big buttons, no clutter, nothing to figure out. Most subs are sending their first pack within minutes.",
	},
	{
		q: "Do I have to change how I work?",
		a: "No. Keep taking your photos the way you always have — Soyer just gives them somewhere to go. Upload to the job when you get a minute, and everything comes together in one place. No new habits, no new routine.",
	},
	{
		q: "What does it cost?",
		a: "Nothing. Soyer is free for everyone — every sub, every job, every pack. No trial that expires, no card required, no catch.",
	},
];
---

<section class="faq section" aria-labelledby="faq-heading">
	<div class="container">
		<p class="eyebrow" id="faq-heading">Common questions</p>

		<div class="faq__list">
			{
				faqs.map((faq) => (
					<details class="faq-item">
						<summary class="faq-item__q">
							<span>{faq.q}</span>
							<span class="faq-item__icon" aria-hidden="true" />
						</summary>
						<p class="faq-item__a">{faq.a}</p>
					</details>
				))
			}
		</div>
	</div>
</section>

<style>
	.faq {
		background: var(--color-surface);
		border-block: 1px solid var(--color-border);
	}

	.faq__list {
		margin-top: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		max-width: 46rem;
	}

	.faq-item {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 0 1.5rem;
	}

	.faq-item__q {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.375rem 0;
		font-size: 1.125rem;
		font-weight: 700;
		cursor: pointer;
		list-style: none;
	}

	.faq-item__q::-webkit-details-marker {
		display: none;
	}

	.faq-item__q:focus-visible {
		outline: 3px solid var(--color-primary);
		outline-offset: 3px;
		border-radius: var(--radius);
	}

	.faq-item__icon {
		position: relative;
		flex: 0 0 auto;
		width: 1.125rem;
		height: 1.125rem;
	}

	.faq-item__icon::before,
	.faq-item__icon::after {
		content: "";
		position: absolute;
		background: var(--color-primary);
		border-radius: 2px;
	}

	.faq-item__icon::before {
		top: 50%;
		left: 0;
		width: 100%;
		height: 2px;
		transform: translateY(-50%);
	}

	.faq-item__icon::after {
		left: 50%;
		top: 0;
		width: 2px;
		height: 100%;
		transform: translateX(-50%);
		transition: opacity 0.15s ease;
	}

	.faq-item[open] .faq-item__icon::after {
		opacity: 0;
	}

	.faq-item__a {
		margin: 0;
		padding: 0 0 1.5rem;
		color: var(--color-text-muted);
		font-size: 1.0625rem;
		max-width: 60ch;
	}
</style>
